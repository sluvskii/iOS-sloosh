<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.NeoMovies" parent="Theme.Material3.DayNight.NoActionBar" />

    <style name="Theme.Player" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowBackground">@android:color/black</item>
        <item name="bottomSheetDialogTheme">@style/BottomSheetDialog.Dark</item>
    </style>

    <style name="BottomSheetDialog.Dark" parent="Theme.Design.Light.BottomSheetDialog">
        <item name="android:windowIsFloating">false</item>
        <item name="bottomSheetStyle">@style/BottomSheet.Dark</item>
    </style>

    <style name="BottomSheet.Dark" parent="Widget.Design.BottomSheet.Modal">
        <item name="android:background">@drawable/bottom_sheet_bg</item>
    </style>

</resources>